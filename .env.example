# GeoFlip configuration — copy to .env and edit before running.

# Map default view (Taipei Main Station)
DEFAULT_CENTER_LAT=25.0330
DEFAULT_CENTER_LON=121.5654
DEFAULT_ZOOM=15

# Nominatim — ToS requires a real User-Agent that identifies your project + contact.
# Replace your-email@example.com with a working address you control.
NOMINATIM_USER_AGENT=geoflip-coursework/0.1 (your-email@example.com)
NOMINATIM_EMAIL=your-email@example.com
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_MIN_INTERVAL_SECONDS=1.0

# OSRM — public demo is rate-limited and occasionally unstable. For heavy
# playtesting, self-host with profile=foot.
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILE=foot

# Local JSON state file
STATE_FILE=data/state.json

# HTTP client timeout (seconds)
REQUEST_TIMEOUT_SECONDS=10

# Flask
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=1
LOG_LEVEL=INFO
# SECRET_KEY=change-me-for-non-dev-use
